# TheShy 的 Riot ID (OP.GG MCP 用 Riot ID 查询)
# TheShy 的实际 Riot ID, 默认 TheShy#KR1
THESHY_RIOT_ID=TheShy#KR1

# 区服: KR (韩服, TheShy 主要在韩服)
THESHY_REGION=KR

# 推送渠道 (至少填一个)
# Bark (推荐): 手机装 Bark App, 复制推送 URL 末尾的字符串
# 完整 URL 也行: https://api.day.app/<key>
BARK_KEY=

# Server酱: https://sct.ftqq.com/ (免费版每天 5 条上限)
SERVERCHAN_KEY=

# Discord Webhook: 频道设置 → 整合 → Webhook → 新建 → 复制 URL
DISCORD_WEBHOOK=
