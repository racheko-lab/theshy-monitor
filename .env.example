# =============================================================================
# TheShy 监控工具配置 (基于 lol_monitor)
# 复制此文件为 .env 并填入你自己的 key
# =============================================================================

# ----- Riot API (必须) -----
# 申请地址: https://developer.riotgames.com/
# 个人 Development Key 24 小时过期需重新生成；Production Key 永久但需审核
# 速率限制: 20 req/s, 100 req/2min (个人 key 足够)
RIOT_API_KEY=

# ----- 监控对象 (可选，默认 TheShy#KR1) -----
# Riot ID 格式: gameName#tagLine
# 如果 TheShy 改名了，在这里更新
# RIOT_ID=TheShy#KR1

# 大区 (默认 kr，可选: kr/na1/euw1/eun1/jp1/br1/la1/la2/oc1/ru/tr1/sg2/tw2/vn2)
# REGION=kr

# ----- 通知渠道 (至少配一个，否则不会推送) -----

# Bark: 手机装 Bark App，复制推送 URL 末尾的字符串
# 例如 https://api.day.app/XXXXXXXX/ ← 取 XXXXXXXX
BARK_KEY=

# Bark 自定义服务器 (可选，默认 https://api.day.app)
# BARK_HOST=https://api.day.app

# Server酱: 在 sct.ftqq.com 申请，SCT 开头
SERVERCHAN_KEY=

# ----- 检查间隔 (可选) -----
# 不在游戏中时检查间隔 (秒，默认 300 = 5 分钟)
# 排位只有开始/结束两个事件，5 分钟足够，API 友好
# POLL_INTERVAL=300

# 在游戏中时检查间隔 (秒，默认 60 = 1 分钟)
# 缩短这个可以在 TheShy 结束比赛的瞬间更快收到通知
# ACTIVE_INTERVAL=60
